    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction (Queue)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"gopay\",\n  \"items\": [\n    {\n      \"ticket_type_id\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"ticket_type_id\": 2,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"]
            },
            "description": "Create a new transaction and enter the queue. User must be authenticated. Returns transaction_id and queue position.\n\nPayment methods: gopay, ovo, qris\nQuantity range: 1-10 per item"
          },
          "response": []
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"]
            },
            "description": "Get list of transactions. Admin sees all transactions, regular users see only their own transactions."
          },
          "response": []
        },
        {
          "name": "Check Queue Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/transactions/queue/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "queue", "1"]
            },
            "description": "Check the queue status of a transaction. Returns queue position, estimated wait time, and status (in_queue, ready, or failed). No authentication required for public queue checking."
          },
          "response": []
        },
        {
          "name": "Get Transaction Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1"]
            },
            "description": "Get detailed information about a specific transaction, including all ticket items. User can only see their own transactions, admins can see all."
          },
          "response": []
        },
        {
          "name": "Update Transaction Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"success\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transactions/1/status",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1", "status"]
            },
            "description": "Update transaction status. Admin only. Valid statuses: pending, success, failed"
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/transactions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions", "1"]
            },
            "description": "Delete a transaction. Admin only."
          },
          "response": []
        }
      ]
